---
import { SITE_TITLE } from '../consts';
---

<!-- 悬浮顶部，带高斯模糊的玻璃态导航栏 -->
<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 backdrop-blur-xl bg-white/60 border-b border-white/40 shadow-[0_10px_30px_-15px_rgba(0,0,0,0.05)]">
	<div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
		
		<div class="flex items-center gap-3">
			<a href="/" class="flex items-center gap-3 no-underline">
				<img src="/logo.svg" alt="Zephyr" class="w-9 h-9 rounded-xl object-cover" />
				<span class="text-sm font-bold tracking-widest text-[var(--color-secondary)] font-cormorant uppercase">Zephyr Blog</span>
			</a>
		</div>

		<nav class="flex items-center gap-2 sm:gap-6 font-cormorant text-lg font-bold tracking-widest uppercase">
			<a class="relative group text-[var(--color-primary)] no-underline px-2 py-1" href="/">
				<span>Home</span>
				<span class="absolute bottom-0 left-0 w-full h-[2px] bg-[var(--color-brand)] scale-x-0 group-hover:scale-x-100 transition-transform origin-center duration-300"></span>
			</a>
			<a class="relative group text-[var(--color-primary)] no-underline px-2 py-1" href="/blog">
				<span>Knowledge</span>
				<span class="absolute bottom-0 left-0 w-full h-[2px] bg-[var(--color-brand)] scale-x-0 group-hover:scale-x-100 transition-transform origin-center duration-300"></span>
			</a>
			<a class="relative group text-[var(--color-primary)] no-underline px-2 py-1" href="/projects">
				<span>Projects</span>
				<span class="absolute bottom-0 left-0 w-full h-[2px] bg-[var(--color-brand)] scale-x-0 group-hover:scale-x-100 transition-transform origin-center duration-300"></span>
			</a>
		</nav>
	</div>
</header>
