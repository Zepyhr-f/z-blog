---
<!-- 自定义右侧滚动条 -->
<div id="custom-scrollbar" class="fixed right-4 md:right-10 top-24 bottom-24 w-4 z-40 hidden sm:flex flex-col items-center pointer-events-none transition-opacity duration-300">
    
    <!-- 上方多余出头的线条 -->
    <div class="absolute -top-8 h-8 w-[1px] bg-[var(--color-border)]/60"></div>

    <!-- 轨道背景 (带断点的小菱形和线段) -->
    <div class="absolute inset-0 flex flex-col items-center justify-between w-full">
        <div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)] transition-colors shrink-0" data-progress="0"></div>
        <div class="flex-1 w-[1px] bg-[var(--color-border)]/60 my-1"></div>
        <div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)] transition-colors shrink-0" data-progress="0.5"></div>
        <div class="flex-1 w-[1px] bg-[var(--color-border)]/60 my-1"></div>
        <div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)] transition-colors shrink-0" data-progress="1"></div>
    </div>

    <!-- 下方多余出头的线条 -->
    <div class="absolute -bottom-8 h-8 w-[1px] bg-[var(--color-border)]/60"></div>

    <!-- 可滑动的透明细长菱形滑块 (用SVG实现透明描边，淡黑色) -->
    <div id="custom-scroll-thumb" class="absolute top-0 -translate-y-1/2 w-3 h-8 z-20 pointer-events-auto cursor-pointer flex justify-center items-center group">
        <svg viewBox="0 0 10 30" class="w-full h-full text-[var(--color-primary)] opacity-70 fill-transparent stroke-current stroke-[1.5] drop-shadow-sm group-hover:fill-[var(--color-primary)]/20 transition-all backdrop-blur-sm">
            <polygon points="5,1 9,15 5,29 1,15"></polygon>
        </svg>
    </div>
</div>

<script>
    let isDragging = false;
    let track: HTMLElement | null = null;
    let thumb: HTMLElement | null = null;

    const updateThumbPosition = () => {
        if (isDragging || !thumb || !track) return;
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        // If content isn't scrollable, hide the scrollbar
        if (scrollHeight <= 0) {
            track.style.opacity = '0';
            track.style.pointerEvents = 'none';
            return;
        }
        track.style.opacity = '1';
        track.style.pointerEvents = '';
        
        const progress = window.scrollY / scrollHeight;
        thumb.style.top = `${Math.max(0, Math.min(100, progress * 100))}%`;
    };

    const onMouseMove = (e: MouseEvent) => {
        if (!isDragging || !track || !thumb) return;
        const trackRect = track.getBoundingClientRect();
        let progress = (e.clientY - trackRect.top) / trackRect.height;
        progress = Math.max(0, Math.min(1, progress));
        
        thumb.style.top = `${progress * 100}%`;
        
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        window.scrollTo(0, progress * scrollHeight);
    };

    const onMouseUp = () => {
        if (isDragging) {
            isDragging = false;
            document.body.style.userSelect = '';
        }
    };

    // Attach global listeners ONCE
    window.addEventListener('scroll', updateThumbPosition, { passive: true });
    window.addEventListener('resize', updateThumbPosition);
    window.addEventListener('mousemove', onMouseMove);
    window.addEventListener('mouseup', onMouseUp);

    // Re-initialize elements on each page load
    document.addEventListener('astro:page-load', () => {
        thumb = document.getElementById('custom-scroll-thumb');
        track = document.getElementById('custom-scrollbar');
        
        if (!thumb || !track) return;

        const onMouseDown = () => {
            isDragging = true;
            document.body.style.userSelect = 'none';
        };
        thumb.addEventListener('mousedown', onMouseDown);

        const nodes = track.querySelectorAll('[data-progress]');
        nodes.forEach(node => {
            node.addEventListener('click', () => {
                const targetProgress = parseFloat(node.getAttribute('data-progress'));
                const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
                window.scrollTo({
                    top: targetProgress * scrollHeight,
                    behavior: 'smooth'
                });
            });
        });

        // Use requestAnimationFrame to ensure DOM is fully ready
        requestAnimationFrame(() => {
            setTimeout(updateThumbPosition, 100);
        });
    });
</script>
