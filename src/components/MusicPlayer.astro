---
---
<div transition:persist="music-player" id="global-music-player" class="w-20 sm:w-24 h-56 flex flex-col items-center py-2 gap-4 pointer-events-auto transition-all">
    
    <!-- Top: 3 Buttons -->
    <div class="w-full flex justify-between items-center px-1">
        <button id="prev-btn" class="w-6 h-6 flex items-center justify-center rounded-full text-[var(--color-primary)] bg-[var(--color-bg-base)]/60 backdrop-blur-sm border border-[var(--color-border)] shadow-sm hover:shadow hover:bg-[var(--color-bg-base)] hover:text-[var(--color-brand)] active:scale-90 transition-all cursor-pointer group" aria-label="Previous track">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="19 20 9 12 19 4 19 20"></polygon><line x1="5" y1="19" x2="5" y2="5" stroke="currentColor" stroke-width="2"></line></svg>
        </button>
        
        <button id="play-btn" class="w-8 h-8 flex flex-shrink-0 items-center justify-center rounded-full text-[var(--color-primary)] bg-[var(--color-bg-base)]/80 backdrop-blur-sm border border-[var(--color-border)] shadow hover:shadow-md hover:bg-[var(--color-bg-base)] hover:text-[var(--color-brand)] active:scale-90 transition-all cursor-pointer group" aria-label="Play or pause">
            <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
            <svg id="pause-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
        </button>

        <button id="next-btn" class="w-6 h-6 flex items-center justify-center rounded-full text-[var(--color-primary)] bg-[var(--color-bg-base)]/60 backdrop-blur-sm border border-[var(--color-border)] shadow-sm hover:shadow hover:bg-[var(--color-bg-base)] hover:text-[var(--color-brand)] active:scale-90 transition-all cursor-pointer group" aria-label="Next track">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 4 15 12 5 20 5 4"></polygon><line x1="19" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2"></line></svg>
        </button>
    </div>
    
    <!-- Divider -->
    <div class="w-12 h-[1px] flex-shrink-0 bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent opacity-80"></div>

    <!-- Bottom: 3 Vertical Text Columns -->
    <div class="flex-1 w-full flex justify-between items-start px-2 overflow-hidden">
        <!-- Prev Track -->
        <span id="prev-track" class="text-[9px] opacity-40 font-serif-sc tracking-[0.2em] text-[var(--color-primary)] whitespace-nowrap select-none transition-all duration-300" style="writing-mode: vertical-rl; text-orientation: upright;"></span>
        
        <!-- Current Track -->
        <span id="curr-track" class="text-xs font-bold font-serif-sc tracking-[0.25em] text-[var(--color-brand)] whitespace-nowrap drop-shadow-sm select-none transition-all duration-300" style="writing-mode: vertical-rl; text-orientation: upright;"></span>
        
        <!-- Next Track -->
        <span id="next-track" class="text-[9px] opacity-40 font-serif-sc tracking-[0.2em] text-[var(--color-primary)] whitespace-nowrap select-none transition-all duration-300" style="writing-mode: vertical-rl; text-orientation: upright;"></span>
    </div>

    <!-- Hidden Audio -->
    <audio id="bg-audio" preload="none"></audio>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const player = document.getElementById('global-music-player');
        if (!player || player.dataset.initialized === 'true') return;
        player.dataset.initialized = 'true';

        const prevBtn = document.getElementById('prev-btn');
        const playBtn = document.getElementById('play-btn');
        const nextBtn = document.getElementById('next-btn');
        const playIcon = document.getElementById('play-icon');
        const pauseIcon = document.getElementById('pause-icon');
        
        const prevTrackEl = document.getElementById('prev-track');
        const currTrackEl = document.getElementById('curr-track');
        const nextTrackEl = document.getElementById('next-track');
        
        const audio = document.getElementById('bg-audio') as HTMLAudioElement;

        const playlist = [
            { title: '海之下', src: '/海之下.mp3' },
            { title: '云之上', src: '/云之上.mp3' },
            { title: '星之尘', src: '/placeholder1.mp3' },
            { title: '风之息', src: '/placeholder2.mp3' }
        ];
        
        let currentIndex = 0;
        let isPlaying = false;

        audio.src = playlist[0].src;

        function updateUI() {
            const prevIndex = (currentIndex - 1 + playlist.length) % playlist.length;
            const nextIndex = (currentIndex + 1) % playlist.length;

            if (prevTrackEl) prevTrackEl.textContent = playlist[prevIndex].title;
            if (currTrackEl) currTrackEl.textContent = playlist[currentIndex].title;
            if (nextTrackEl) nextTrackEl.textContent = playlist[nextIndex].title;

            if (isPlaying) {
                playIcon?.classList.add('hidden');
                pauseIcon?.classList.remove('hidden');
            } else {
                playIcon?.classList.remove('hidden');
                pauseIcon?.classList.add('hidden');
            }
        }

        // Initialize UI
        updateUI();

        function togglePlay() {
            if (isPlaying) {
                audio.pause();
                isPlaying = false;
            } else {
                audio.play().catch(e => console.log('Playback prevented', e));
                isPlaying = true;
            }
            updateUI();
        }

        function prevTrack() {
            currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
            loadAndPlay();
        }

        function nextTrack() {
            currentIndex = (currentIndex + 1) % playlist.length;
            loadAndPlay();
        }

        function loadAndPlay() {
            audio.src = playlist[currentIndex].src;
            audio.load();
            if (isPlaying) {
                audio.play().catch(e => console.log('Playback prevented', e));
            }
            updateUI();
        }

        playBtn?.addEventListener('click', togglePlay);
        prevBtn?.addEventListener('click', prevTrack);
        nextBtn?.addEventListener('click', nextTrack);
        audio.addEventListener('ended', nextTrack);
    });
</script>
