---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import GlobalBackground from '../../components/GlobalBackground.astro';
import { SITE_TITLE } from '../../consts';

const projects = [
	{
		name: 'Zephyr Go',
		desc: '基于 Go-Zero 微服务框架构建的企业级后端服务，包含身份认证、API 网关、权限管理等核心模块。采用领域驱动设计思想，支持水平扩展。',
		tags: ['Go-Zero', 'gRPC', 'PostgreSQL', 'Redis'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-go',
		demo: null,
	},
	{
		name: 'Zephyr AI',
		desc: '智能对话与 RAG 知识库引擎，集成 DeepSeek 大模型与火山引擎多模态向量服务，提供智能问答、文档检索、代码生成等 AI 能力。',
		tags: ['Python', 'FastAPI', 'RAG', 'LLM'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-ai',
		demo: null,
	},
	{
		name: 'Zephyr Admin React',
		desc: '企业级后台管理系统前端，基于 React + TypeScript 构建，采用 Ant Design Pro 架构，支持动态路由、权限控制、多语言等特性。',
		tags: ['React', 'TypeScript', 'Ant Design', 'Vite'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-admin-react',
		demo: 'http://admin.zephyr.green',
	},
	{
		name: 'Zephyr Blog',
		desc: '个人博客与开源项目展示平台，基于 Astro 静态站点生成器构建，采用现代前端技术栈，支持 Markdown 文章与自定义主题。',
		tags: ['Astro', 'Tailwind CSS', 'Static Site'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-blog',
		demo: null,
	},
	{
		name: 'Zephyr Docs',
		desc: 'Zephyr 系列项目的统一文档中心，包含架构设计、API 接口、部署指南、开发规范等完整文档，使用 MkDocs 构建。',
		tags: ['MkDocs', 'Documentation', 'Architecture'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-docs',
		demo: null,
	},
	{
		name: 'Zephyr Infra',
		desc: '基础设施即代码，包含 Docker Compose 编排、Kubernetes 配置、CI/CD 流水线、监控告警等完整的生产级部署方案。',
		tags: ['Docker', 'Kubernetes', 'CI/CD', 'Terraform'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-infra',
		demo: null,
	},
	{
		name: 'Zephyr Skills',
		desc: 'AI Agent 技能库，为 Hermes、Claude Code 等 AI Agent 提供可复用的工作流与最佳实践，加速开发效率。',
		tags: ['AI Agent', 'Workflow', 'Prompt Engineering'],
		status: 'active',
		href: 'https://github.com/Zepyhr-f/zephyr-skills',
		demo: null,
	},
	{
		name: 'Zephyr Scripts',
		desc: '运维自动化脚本集合，包含部署、备份、监控、日志分析等实用工具，采用 Shell 和 Python 编写，开箱即用。',
		tags: ['Shell', 'Python', 'DevOps', 'Automation'],
		status: 'active',
		href: null,
		demo: null,
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`开源项目 · ${SITE_TITLE}`} description="将设想转化为现实的开源项目集合" />
		<style>
			@keyframes wordIn {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
			.card-enter {
				animation: wordIn 0.5s cubic-bezier(0.23, 1, 0.32, 1) backwards;
			}
		</style>
	</head>
	<body class="bg-[var(--color-bg-base)] relative overflow-x-hidden min-h-screen flex flex-col">
		<GlobalBackground />

		<Header />

		<!-- Hero Background Image -->
		<div class="relative w-full h-[50vh] md:h-[60vh] overflow-hidden mb-16">
			<div 
				class="absolute inset-0 bg-cover bg-center bg-no-repeat transform scale-105"
				style="background-image: url('/shinichi-ran-bg.png');"
			></div>
			<div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--color-bg-base)]"></div>
			<div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-base)] via-[var(--color-bg-base)]/20 to-transparent"></div>
			
			<!-- Hero Content -->
			<div class="relative z-10 h-full flex flex-col justify-end max-w-5xl mx-auto px-6 pb-12">
				<p class="text-xs font-bold tracking-[0.3em] uppercase text-[var(--color-brand)] mb-3 drop-shadow-lg">Open Source</p>
				<h1 class="text-4xl md:text-6xl font-playfair font-bold text-white mb-4 drop-shadow-2xl">开源项目</h1>
				<p class="text-white/90 text-lg leading-relaxed max-w-xl drop-shadow-lg">
					将设想转化为现实。记录独立项目的实现细节与架构设计，每一行代码都是一次探索。
				</p>
			</div>
		</div>

		<main class="relative z-10 w-full max-w-5xl mx-auto px-6 pb-20 flex-1">

			<!-- Projects Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{projects.map((project, i) => (
					<div
						class={`glass-panel rounded-2xl p-7 flex flex-col gap-4 card-enter ${project.href ? 'hover:-translate-y-1 transition-transform duration-300' : 'opacity-70'}`}
						style={`animation-delay: ${i * 0.08}s`}
					>
						<div class="flex items-start justify-between">
							<div>
								<h2 class="text-xl font-bold font-serif-sc text-[var(--color-primary)] m-0">{project.name}</h2>
							</div>
							<span class={`text-[10px] font-bold tracking-widest uppercase px-2 py-1 rounded-full ${project.status === 'active' ? 'bg-[var(--color-brand)]/10 text-[var(--color-brand)]' : 'bg-[var(--color-border)] text-[var(--color-tertiary)]'}`}>
								{project.status === 'active' ? 'Active' : 'Soon'}
							</span>
						</div>

						<div class="h-[1px] w-full bg-gradient-to-r from-[var(--color-brand)]/20 to-transparent"></div>

						<p class="text-sm text-[var(--color-secondary)] leading-relaxed m-0 flex-1">
							{project.desc}
						</p>

						{project.tags.length > 0 && (
							<div class="flex flex-wrap gap-2">
								{project.tags.map(tag => (
									<span class="px-2 py-1 rounded bg-[var(--color-primary)]/5 border border-[var(--color-border)] text-xs font-medium text-[var(--color-primary)]">
										{tag}
									</span>
								))}
							</div>
						)}

						{project.href && (
							<div class="mt-1 flex items-center gap-6">
								{project.demo && (
									<a
										href={project.demo}
										target="_blank"
										rel="noopener noreferrer"
										class="flex items-center gap-2 text-sm font-bold text-[var(--color-brand)] no-underline hover:gap-3 transition-all"
									>
										在线演示
										<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
									</a>
								)}
								<a
									href={project.href}
									target="_blank"
									rel="noopener noreferrer"
									class="flex items-center gap-1.5 text-sm font-medium text-[var(--color-secondary)] hover:text-[var(--color-brand)] transition-colors no-underline"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
									查看源码
								</a>
							</div>
						)}
					</div>
				))}
			</div>
		</main>

		<div class="mt-auto pb-8">
			<Footer />
		</div>
	</body>
</html>
