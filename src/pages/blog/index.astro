---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import GlobalBackground from '../../components/GlobalBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`知识分享 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			@keyframes wordIn {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
			.card-enter {
				animation: wordIn 0.5s cubic-bezier(0.23, 1, 0.32, 1) backwards;
			}
		</style>
	</head>
	<body class="bg-[var(--color-bg-base)] relative overflow-x-hidden min-h-screen flex flex-col">
		<GlobalBackground />

		<Header />

		<main class="relative z-10 w-full max-w-5xl mx-auto px-6 pt-28 pb-20 flex-1">
			<!-- Page Header -->
			<div class="mb-12">
				<p class="text-xs font-bold tracking-[0.3em] uppercase text-[var(--color-brand)] mb-3">Knowledge</p>
				<h1 class="text-4xl md:text-5xl font-playfair font-bold text-[var(--color-primary)] mb-4">知识分享</h1>
				<div class="h-[1px] w-16 bg-[var(--color-brand)]/40"></div>
				<p class="mt-4 text-[var(--color-secondary)] text-base leading-relaxed max-w-xl">
					记录前端工程化、微服务架构与读书随笔的技术沉淀，以及开发过程中的踩坑经验。
				</p>
			</div>

			<!-- Posts Grid -->
			{posts.length === 0 ? (
				<div class="glass-panel rounded-2xl p-16 text-center">
					<p class="text-[var(--color-tertiary)] text-lg">暂无文章，敬请期待…</p>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{posts.map((post, i) => (
						<a
							href={`/blog/${post.id}/`}
							class="glass-panel rounded-2xl p-6 no-underline text-inherit flex flex-col gap-3 hover:-translate-y-1 transition-transform duration-300 card-enter"
							style={`animation-delay: ${i * 0.05}s`}
						>
							<div class="flex items-center justify-between">
								<span class="text-xs font-bold tracking-widest uppercase text-[var(--color-brand)]">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-tertiary)]"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</div>
							<div class="h-[1px] w-full bg-gradient-to-r from-[var(--color-brand)]/20 to-transparent"></div>
							<h2 class="text-lg font-bold font-serif-sc text-[var(--color-primary)] leading-snug m-0">
								{post.data.title}
							</h2>
							<p class="text-sm text-[var(--color-secondary)] leading-relaxed m-0 line-clamp-3">
								{post.data.description}
							</p>
						</a>
					))}
				</div>
			)}
		</main>

		<div class="mt-auto pb-8">
			<Footer />
		</div>
	</body>
</html>
