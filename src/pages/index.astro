---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<!doctype html>
<html lang="en" class="scroll-smooth scroll-pt-20">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 内联样式补充背景特效 */
			.noise-bg {
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
				opacity: 0.04;
				mix-blend-mode: multiply;
				pointer-events: none;
				position: fixed;
				inset: 0;
				z-index: 0;
			}
			.meteor-container {
				display: none;
				position: fixed;
				inset: 0;
				overflow: hidden;
				pointer-events: none;
				z-index: 1;
			}
			:global(.dark) .meteor-container {
				display: block;
			}
			.meteor {
				position: absolute;
				width: 2px;
				height: 150px;
				background: linear-gradient(to bottom, transparent, var(--color-brand));
				opacity: 0;
				animation: meteor-fall linear infinite;
			}
			.meteor::after {
				content: '';
				position: absolute;
				bottom: -2px;
				left: 50%;
				transform: translateX(-50%);
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: var(--color-brand);
				box-shadow: 0 0 12px 3px var(--color-brand);
			}
			@keyframes meteor-fall {
				0% {
					opacity: 0;
					transform: rotate(-45deg) translateY(-200px);
				}
				5% {
					opacity: 1;
				}
				40% {
					opacity: 0;
					transform: rotate(-45deg) translateY(2500px);
				}
				100% {
					opacity: 0;
					transform: rotate(-45deg) translateY(2500px);
				}
			}
			/* Flip Card Styles */
			.flip-card {
				perspective: 1500px;
			}
			.flip-card-inner {
				position: relative;
				width: 100%;
				height: 100%;
				transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
				transform-style: preserve-3d;
			}
			.flip-card:hover .flip-card-inner {
				transform: rotateY(180deg);
			}
			.flip-card-front, .flip-card-back {
				position: absolute;
				inset: 0;
			}
			.flip-card-back {
				transform: rotateY(180deg);
				opacity: 0;
				transition: opacity 0s 0.25s;
				pointer-events: none;
			}
			.flip-card:hover .flip-card-back {
				opacity: 1;
				pointer-events: auto;
				transition: opacity 0s 0.3s;
			}
			.flip-card-front {
				opacity: 1;
				transition: opacity 0s 0.25s;
			}
			.flip-card:hover .flip-card-front {
				opacity: 0;
				pointer-events: none;
				transition: opacity 0s 0.3s;
			}

			/* Celestial Scene Animations */
			.celestial-sun {
				transform: translateY(0) scale(1);
				opacity: 1;
				transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
			}
			.celestial-moon {
				transform: translateY(100px) scale(0.8);
				opacity: 0;
				transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
			}

			:global(.dark) .celestial-sun {
				transform: translateY(120px) scale(0.8);
				opacity: 0;
			}
			:global(.dark) .celestial-moon {
				transform: translateY(0) scale(1);
				opacity: 1;
			}
		</style>
	</head>
	<body class="bg-[var(--color-bg-base)] relative overflow-x-hidden min-h-screen flex flex-col">
		
		<!-- 全局动效背景 -->
		<div class="fixed inset-0 z-0 bg-gradient-to-t from-[var(--color-bg-gradient-from)] via-[var(--color-bg-gradient-via)] via-40% to-[var(--color-bg-gradient-to)] pointer-events-none"></div>
		<div class="noise-bg"></div>
		<!-- 动态流星背景 -->
		<div class="meteor-container">
			<div class="meteor" style="top: -10%; left: 70%; animation-duration: 7s; animation-delay: 0s;"></div>
			<div class="meteor" style="top: -20%; left: 90%; animation-duration: 9s; animation-delay: 2s;"></div>
			<div class="meteor" style="top: 10%; left: 110%; animation-duration: 6s; animation-delay: 1.5s;"></div>
			<div class="meteor" style="top: -5%; left: 40%; animation-duration: 8s; animation-delay: 4s;"></div>
			<div class="meteor" style="top: 20%; left: 120%; animation-duration: 10s; animation-delay: 3s;"></div>
			<div class="meteor" style="top: -30%; left: 80%; animation-duration: 8.5s; animation-delay: 5s;"></div>
		</div>
		
		<!-- 昼夜交替特效背景 (素描风) -->
		<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
			<!-- 太阳 (右上角) -->
			<div class="celestial-sun absolute top-16 right-10 md:right-24 w-16 h-16 md:w-20 md:h-20 text-[var(--color-primary)] opacity-60">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5" stroke-width="1.2" />
					<circle cx="11.5" cy="12.5" r="4.5" stroke-width="0.5" />
					<path d="M 12 2 L 12 5 M 12 19 L 12 22 M 2 12 L 5 12 M 19 12 L 22 12" stroke-width="1.2" />
					<path d="M 4.93 4.93 L 7 7 M 17 17 L 19.07 19.07 M 4.93 19.07 L 7 17 M 17 7 L 19.07 4.93" stroke-width="1.2" />
				</svg>
			</div>

			<!-- 月亮 (左上角) -->
			<div class="celestial-moon absolute top-16 left-10 md:left-24 w-16 h-16 md:w-20 md:h-20 text-[var(--color-primary)] opacity-60">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
					<path d="M 21 12.79 A 9 9 0 1 1 11.21 3 A 7 7 0 0 0 21 12.79 Z" stroke-width="1.2" />
					<path d="M 19 12.5 A 7.5 7.5 0 1 1 11.5 5 A 5.5 5.5 0 0 0 19 12.5 Z" stroke-width="0.5" />
				</svg>
			</div>
		</div>
		


		<Header />
		
		<!-- 自定义右侧滚动条 -->
		<div id="custom-scrollbar" class="fixed right-4 md:right-10 top-24 bottom-24 w-4 z-40 hidden sm:flex flex-col items-center pointer-events-none">
            
            <!-- 上方多余出头的线条 -->
            <div class="absolute -top-8 h-8 w-[1px] bg-[var(--color-border)]/60"></div>

			<!-- 轨道背景 (带断点的小菱形和线段) -->
			<div class="absolute inset-0 flex flex-col items-center justify-between w-full">
				<div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)]/30 transition-colors shrink-0" data-progress="0"></div>
				<div class="flex-1 w-[1px] bg-[var(--color-border)]/60 my-1"></div>
				<div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)]/30 transition-colors shrink-0" data-progress="0.5"></div>
				<div class="flex-1 w-[1px] bg-[var(--color-border)]/60 my-1"></div>
				<div class="w-2 h-2 rotate-45 border border-[var(--color-tertiary)]/60 z-10 cursor-pointer pointer-events-auto hover:bg-[var(--color-tertiary)]/30 transition-colors shrink-0" data-progress="1"></div>
			</div>

            <!-- 下方多余出头的线条 -->
            <div class="absolute -bottom-8 h-8 w-[1px] bg-[var(--color-border)]/60"></div>

			<!-- 可滑动的透明细长菱形滑块 (用SVG实现透明描边) -->
			<div id="custom-scroll-thumb" class="absolute top-0 -translate-y-1/2 w-3 h-8 z-20 pointer-events-auto cursor-pointer flex justify-center items-center group">
				<svg viewBox="0 0 10 30" class="w-full h-full text-[var(--color-brand)] fill-transparent stroke-current stroke-[1.5] drop-shadow-sm group-hover:fill-[var(--color-brand)]/20 transition-colors backdrop-blur-sm">
					<polygon points="5,1 9,15 5,29 1,15"></polygon>
				</svg>
			</div>
		</div>

		<script>
			// 滚动条交互逻辑
			document.addEventListener('DOMContentLoaded', () => {
				const thumb = document.getElementById('custom-scroll-thumb');
				const track = document.getElementById('custom-scrollbar');
				if (!thumb || !track) return;

				let isDragging = false;

				const updateThumbPosition = () => {
					if (isDragging) return;
					const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
					if (scrollHeight <= 0) {
						thumb.style.opacity = '0';
						return;
					}
					thumb.style.opacity = '1';
					const progress = window.scrollY / scrollHeight;
					thumb.style.top = `${Math.max(0, Math.min(100, progress * 100))}%`;
				};

				window.addEventListener('scroll', updateThumbPosition, { passive: true });
				window.addEventListener('resize', updateThumbPosition);
				
				setTimeout(updateThumbPosition, 100);

				// 拖拽逻辑
				thumb.addEventListener('mousedown', () => {
					isDragging = true;
					document.body.style.userSelect = 'none';
				});

				window.addEventListener('mousemove', (e) => {
					if (!isDragging) return;
					const trackRect = track.getBoundingClientRect();
					let progress = (e.clientY - trackRect.top) / trackRect.height;
					progress = Math.max(0, Math.min(1, progress));
					
					thumb.style.top = `${progress * 100}%`;
					
					const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
					window.scrollTo(0, progress * scrollHeight);
				});

				window.addEventListener('mouseup', () => {
					if (isDragging) {
						isDragging = false;
						document.body.style.userSelect = '';
					}
				});

				// 点击节点跳转逻辑
				const nodes = document.querySelectorAll('#custom-scrollbar [data-progress]');
				nodes.forEach(node => {
					node.addEventListener('click', () => {
						const targetProgress = parseFloat(node.getAttribute('data-progress'));
						const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
						window.scrollTo({
							top: targetProgress * scrollHeight,
							behavior: 'smooth'
						});
					});
				});
			});
		</script>

		<main class="relative z-10 w-full max-w-6xl mx-auto px-6 flex flex-col items-center flex-1">
			
			<!-- Hero Section (Section 1) -->
			<section id="hero" class="w-full min-h-screen flex flex-col justify-center items-center relative">
				
				<!-- 动效标题 -->
				<div class="text-center mb-8 -mt-16">
					<h1 class="text-5xl md:text-7xl font-playfair font-bold text-[var(--color-primary)] leading-tight tracking-tight m-0">
						<span class="animate-word delay-1">Hi,</span> 
						<span class="animate-word delay-2">I'm</span> 
						<span class="animate-word delay-3 text-[var(--color-brand)] italic">Zephyr</span>
					</h1>
					<!-- 分割线 -->
					<div class="flex items-center justify-center gap-4 my-8">
						<div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-[var(--color-brand)]/50"></div>
						<div class="w-1.5 h-1.5 rotate-45 border border-[var(--color-brand)]/50"></div>
						<div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-[var(--color-brand)]/50"></div>
					</div>
					<p class="text-lg md:text-xl font-serif-sc text-[var(--color-secondary)] tracking-widest font-light animate-word delay-4 m-0">
						致虚极，守静笃。在代码与现实的交错中探索。
					</p>
				</div>

				<!-- 无缝滚动标签 -->
				<div class="w-full max-w-2xl overflow-hidden mb-12 mask-image-gradient relative">
					<!-- Tailwind 没有内置 mask-image，用透明度渐变的左右遮罩模拟 -->
					<div class="absolute inset-y-0 left-0 w-12 bg-gradient-to-r from-[var(--color-bg-base)] to-transparent z-10"></div>
					<div class="absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-[var(--color-bg-base)] to-transparent z-10"></div>
					
					<div class="flex gap-4 w-max" style="animation: marquee 20s linear infinite;">
						<!-- 复制两遍实现无缝 -->
						<div class="flex gap-4 pr-4">
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Frontend</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Backend Architecture</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Go-Zero</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>React & Astro</span>
						</div>
						<div class="flex gap-4">
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Frontend</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Backend Architecture</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>Go-Zero</span>
							<span class="glass-panel px-4 py-2 rounded-full text-sm font-medium text-[var(--color-secondary)] whitespace-nowrap"><span class="text-[var(--color-brand)] mr-1">#</span>React & Astro</span>
						</div>
					</div>
				</div>

				<!-- 首屏专属音乐播放器 (随页面滚动) -->
				<div class="z-30 mt-4 transition-transform duration-300 hover:scale-105">
					<MusicPlayer />
				</div>
			</section>

			<!-- Section 2: Categories -->
			<section id="categories" class="w-full min-h-screen flex flex-col justify-center items-center">
				<div class="w-full mb-12">
					<h2 class="text-3xl md:text-4xl font-playfair font-bold text-[var(--color-primary)] text-center">Explorations</h2>
					<p class="text-sm font-serif-sc tracking-widest text-[var(--color-secondary)] mt-3 text-center">文章专栏与独立项目</p>
				</div>
				<!-- 模块内容区：四栏极简卡片 (Flip Card) -->
				<div class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 border-y border-[var(--color-border)] py-10 relative">
					<span class="absolute -top-3 left-6 bg-[var(--color-bg-base)] px-2 text-[10px] font-mono text-[var(--color-tertiary)] tracking-widest">// SECTIONS</span>
				
				<!-- 知识分享 Card -->
				<section id="knowledge" class="flex h-[22rem]">
					<div class="flip-card w-full h-full group">
						<div class="flip-card-inner">
							<!-- Front Face (Tech Style) -->
							<div class="flip-card-front bg-[var(--color-bg-base)] rounded-xl border border-[var(--color-border)] flex flex-col justify-between p-4 shadow-sm group-hover:shadow-md transition-shadow duration-500 overflow-hidden">
								<div class="flex justify-between text-[10px] text-[var(--color-tertiary)] uppercase tracking-wider font-mono opacity-80">
									<span>/ SKILL_01</span>
									<span>v1.0.0</span>
								</div>
								<div class="my-4 flex-1 w-full bg-[var(--color-primary)]/5 rounded-lg border border-[var(--color-border)]/50 flex flex-col items-center justify-center relative overflow-hidden">
									<span class="absolute top-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute top-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<svg class="w-16 h-16 text-[var(--color-brand)] drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
								</div>
								<div class="mb-3">
									<h2 class="text-xl font-bold text-[var(--color-primary)] font-serif-sc tracking-wide m-0">知识分享</h2>
									<p class="text-[10px] text-[var(--color-secondary)] font-mono mt-1 opacity-80 flex items-center gap-1 m-0">
										<span class="text-[var(--color-brand)] text-[8px]">▶</span> /skills/knowledge
									</p>
								</div>
								<div class="pt-3 border-t border-[var(--color-border)]/30 flex justify-between items-center text-[10px] text-[var(--color-tertiary)] font-mono opacity-70">
									<span>// 01</span>
									<span>FIG.01</span>
								</div>
							</div>
							
							<!-- Back Face -->
							<div class="flip-card-back bg-[var(--color-bg-base)] rounded-xl p-5 flex flex-col justify-between border-[var(--color-brand)]/30 border-2 shadow-lg">
								<div>
									<h3 class="text-xl m-0 font-serif-sc font-bold text-[var(--color-primary)] mb-3">知识分享</h3>
									<p class="text-[var(--color-secondary)] leading-relaxed text-sm m-0">
										在前端工程化、微服务后端架构以及读书随笔中寻找平衡点。这里记录了开发过程中的踩坑经验与技术沉淀。
									</p>
									<div class="mt-4 flex flex-wrap gap-1.5">
										<span class="px-2 py-0.5 rounded bg-[var(--color-primary)]/5 border border-[var(--color-border)] text-[10px] font-medium text-[var(--color-secondary)]">React / Astro</span>
										<span class="px-2 py-0.5 rounded bg-[var(--color-primary)]/5 border border-[var(--color-border)] text-[10px] font-medium text-[var(--color-secondary)]">Go-Zero</span>
									</div>
								</div>
								<a href="/blog" class="mt-auto w-full py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-center text-sm font-bold tracking-widest hover:brightness-110 hover:-translate-y-0.5 transition-all no-underline shadow-md shadow-[var(--color-brand)]/20">
									进入专栏 &rarr;
								</a>
							</div>
						</div>
					</div>
				</section>

				<!-- 开源项目 Card -->
				<section id="projects" class="flex h-[22rem]">
					<div class="flip-card w-full h-full group">
						<div class="flip-card-inner">
							<div class="flip-card-front bg-[var(--color-bg-base)] rounded-xl border border-[var(--color-border)] flex flex-col justify-between p-4 shadow-sm group-hover:shadow-md transition-shadow duration-500 overflow-hidden">
								<div class="flex justify-between text-[10px] text-[var(--color-tertiary)] uppercase tracking-wider font-mono opacity-80">
									<span>/ SKILL_02</span>
									<span>v1.0.0</span>
								</div>
								<div class="my-4 flex-1 w-full bg-[var(--color-primary)]/5 rounded-lg border border-[var(--color-border)]/50 flex flex-col items-center justify-center relative overflow-hidden">
									<span class="absolute top-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute top-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<svg class="w-16 h-16 text-[var(--color-brand)] drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
								</div>
								<div class="mb-3">
									<h2 class="text-xl font-bold text-[var(--color-primary)] font-serif-sc tracking-wide m-0">开源项目</h2>
									<p class="text-[10px] text-[var(--color-secondary)] font-mono mt-1 opacity-80 flex items-center gap-1 m-0">
										<span class="text-[var(--color-brand)] text-[8px]">▶</span> /skills/projects
									</p>
								</div>
								<div class="pt-3 border-t border-[var(--color-border)]/30 flex justify-between items-center text-[10px] text-[var(--color-tertiary)] font-mono opacity-70">
									<span>// 02</span>
									<span>FIG.02</span>
								</div>
							</div>
							
							<div class="flip-card-back bg-[var(--color-bg-base)] rounded-xl p-5 flex flex-col justify-between border-[var(--color-brand)]/30 border-2 shadow-lg">
								<div>
									<h3 class="text-xl m-0 font-serif-sc font-bold text-[var(--color-primary)] mb-3">开源项目</h3>
									<p class="text-[var(--color-secondary)] leading-relaxed text-sm m-0">
										将设想转化为现实。包括企业级后台系统 Zephyr Admin 等独立项目的实现细节与架构设计。
									</p>
									<div class="mt-4 flex flex-wrap gap-1.5">
										<span class="px-2 py-0.5 rounded bg-[var(--color-primary)]/5 border border-[var(--color-border)] text-[10px] font-medium text-[var(--color-secondary)]">Zephyr Admin</span>
									</div>
								</div>
								<a href="/projects" class="mt-auto w-full py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-center text-sm font-bold tracking-widest hover:brightness-110 hover:-translate-y-0.5 transition-all no-underline shadow-md shadow-[var(--color-brand)]/20">
									查看项目 &rarr;
								</a>
							</div>
						</div>
					</div>
				</section>

				<!-- 生活随笔 Card -->
				<section id="life" class="flex h-[22rem]">
					<div class="flip-card w-full h-full group">
						<div class="flip-card-inner">
							<div class="flip-card-front bg-[var(--color-bg-base)] rounded-xl border border-[var(--color-border)] flex flex-col justify-between p-4 shadow-sm group-hover:shadow-md transition-shadow duration-500 overflow-hidden">
								<div class="flex justify-between text-[10px] text-[var(--color-tertiary)] uppercase tracking-wider font-mono opacity-80">
									<span>/ SKILL_03</span>
									<span>v1.0.0</span>
								</div>
								<div class="my-4 flex-1 w-full bg-[var(--color-primary)]/5 rounded-lg border border-[var(--color-border)]/50 flex flex-col items-center justify-center relative overflow-hidden">
									<span class="absolute top-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute top-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<svg class="w-16 h-16 text-[var(--color-brand)] drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
								</div>
								<div class="mb-3">
									<h2 class="text-xl font-bold text-[var(--color-primary)] font-serif-sc tracking-wide m-0">生活随笔</h2>
									<p class="text-[10px] text-[var(--color-secondary)] font-mono mt-1 opacity-80 flex items-center gap-1 m-0">
										<span class="text-[var(--color-brand)] text-[8px]">▶</span> /skills/life-notes
									</p>
								</div>
								<div class="pt-3 border-t border-[var(--color-border)]/30 flex justify-between items-center text-[10px] text-[var(--color-tertiary)] font-mono opacity-70">
									<span>// 03</span>
									<span>FIG.03</span>
								</div>
							</div>
							
							<div class="flip-card-back bg-[var(--color-bg-base)] rounded-xl p-5 flex flex-col justify-between border-[var(--color-brand)]/30 border-2 shadow-lg">
								<div>
									<h3 class="text-xl m-0 font-serif-sc font-bold text-[var(--color-primary)] mb-3">生活随笔</h3>
									<p class="text-[var(--color-secondary)] leading-relaxed text-sm m-0">
										记录离开键盘后的世界。摄影、旅行、阅读，以及那些闪光的日常瞬间。
									</p>
								</div>
								<a href="/notes" class="mt-auto w-full py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-center text-sm font-bold tracking-widest hover:brightness-110 hover:-translate-y-0.5 transition-all no-underline shadow-md shadow-[var(--color-brand)]/20">
									阅读随笔 &rarr;
								</a>
							</div>
						</div>
					</div>
				</section>

				<!-- 关于我 Card -->
				<section id="about" class="flex h-[22rem]">
					<div class="flip-card w-full h-full group">
						<div class="flip-card-inner">
							<div class="flip-card-front bg-[var(--color-bg-base)] rounded-xl border border-[var(--color-border)] flex flex-col justify-between p-4 shadow-sm group-hover:shadow-md transition-shadow duration-500 overflow-hidden">
								<div class="flex justify-between text-[10px] text-[var(--color-tertiary)] uppercase tracking-wider font-mono opacity-80">
									<span>/ SKILL_04</span>
									<span>v1.0.0</span>
								</div>
								<div class="my-4 flex-1 w-full bg-[var(--color-primary)]/5 rounded-lg border border-[var(--color-border)]/50 flex flex-col items-center justify-center relative overflow-hidden">
									<span class="absolute top-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute top-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 left-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<span class="absolute bottom-2 right-2 text-[var(--color-tertiary)] text-[8px] font-mono">+</span>
									<svg class="w-16 h-16 text-[var(--color-brand)] drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
								</div>
								<div class="mb-3">
									<h2 class="text-xl font-bold text-[var(--color-primary)] font-serif-sc tracking-wide m-0">关于我</h2>
									<p class="text-[10px] text-[var(--color-secondary)] font-mono mt-1 opacity-80 flex items-center gap-1 m-0">
										<span class="text-[var(--color-brand)] text-[8px]">▶</span> /skills/about-me
									</p>
								</div>
								<div class="pt-3 border-t border-[var(--color-border)]/30 flex justify-between items-center text-[10px] text-[var(--color-tertiary)] font-mono opacity-70">
									<span>// 04</span>
									<span>FIG.04</span>
								</div>
							</div>
							
							<div class="flip-card-back bg-[var(--color-bg-base)] rounded-xl p-5 flex flex-col justify-between border-[var(--color-brand)]/30 border-2 shadow-lg">
								<div>
									<h3 class="text-xl m-0 font-serif-sc font-bold text-[var(--color-primary)] mb-3">关于我</h3>
									<p class="text-[var(--color-secondary)] leading-relaxed text-sm m-0">
										了解 Zephyr 的技能栈、职业经历和联系方式。欢迎随时与我建立连接。
									</p>
								</div>
								<a href="/about" class="mt-auto w-full py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-center text-sm font-bold tracking-widest hover:brightness-110 hover:-translate-y-0.5 transition-all no-underline shadow-md shadow-[var(--color-brand)]/20">
									了解更多 &rarr;
								</a>
							</div>
						</div>
					</div>
				</section>

			</div>
			</section>

			<!-- Section 3: Recent Updates -->
			<section id="recent-posts" class="w-full min-h-screen flex flex-col justify-center items-center">
				<div class="w-full mb-12 flex justify-between items-end border-b border-[var(--color-border)] pb-4">
					<div>
						<h2 class="text-3xl md:text-4xl font-playfair font-bold text-[var(--color-primary)]">Recent Updates</h2>
						<p class="text-sm font-serif-sc tracking-widest text-[var(--color-secondary)] mt-2">最新动态</p>
					</div>
					<a href="/blog" class="text-xs font-mono tracking-widest text-[var(--color-brand)] hover:underline opacity-80 hover:opacity-100 transition-opacity">VIEW ALL -></a>
				</div>
				
				<div class="w-full flex flex-col gap-6">
					{posts.length > 0 ? (
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="group block w-full p-6 bg-[var(--color-bg-base)] border border-[var(--color-border)] rounded-xl hover:bg-[var(--color-primary)]/5 transition-colors relative overflow-hidden">
								<div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-transparent to-[var(--color-brand)] opacity-0 group-hover:opacity-100 transition-opacity"></div>
								<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 relative z-10">
									<div>
										<h3 class="text-xl font-bold font-serif-sc text-[var(--color-primary)] group-hover:text-[var(--color-brand)] transition-colors m-0">{post.data.title}</h3>
										<p class="text-sm text-[var(--color-secondary)] mt-2 opacity-80 font-serif-sc m-0 line-clamp-2">{post.data.description}</p>
									</div>
									<div class="flex-shrink-0 text-xs font-mono text-[var(--color-tertiary)] bg-[var(--color-bg-base)] px-3 py-1 rounded-full border border-[var(--color-border)]">
										<time datetime={post.data.pubDate.toISOString()}>
											{post.data.pubDate.toLocaleDateString('en-us', {
												year: 'numeric',
												month: 'short',
												day: 'numeric',
											})}
										</time>
									</div>
								</div>
							</a>
						))
					) : (
						<div class="text-center py-10 text-[var(--color-tertiary)] font-serif-sc text-sm">
							<p>暂无动态</p>
						</div>
					)}
				</div>
			</section>

		</main>
		
		<div class="w-full pb-8">
			<Footer />
		</div>
		
	</body>
</html>
